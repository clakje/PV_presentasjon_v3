            "tekst_tema": "lys",
            "innhold_html": "<div class=\"layout-presentatorer\"><div class=\"presentator venstre\"><div class=\"bilde-container\"><img src=\"assets/images/Claes.jpg\" alt=\"Claes Kjelshus\"></div><div class=\"tekst-container\"><h2>Claes Kjelshus</h2><p>Regionalt senter for digital læring og kompetanseheving (RegDig), HSØ<br><a href=\"mailto:clakje@ahus.no\">clakje@ahus.no</a></p></div></div><div class=\"strek-container\"><div class=\"animert-strek\"></div></div><div class=\"presentator hoyre\"><div class=\"bilde-container\"><img src=\"assets/images/Benedicte.jpg\" alt=\"Benedicte Lynum\"></div><div class=\"tekst-container\"><h2>Benedicte Lynum</h2><p>Digital læring, Ahus<br><a href=\"mailto:belynu@ahus.no\">belynu@ahus.no</a></p></div></div></div>"
